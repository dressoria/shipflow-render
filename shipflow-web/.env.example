# ShipFlow Web environment example.
# Do not put real secrets in this file.
# Copy to .env.local for local development and fill values there.

# Supabase public, visible in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase private, server/backend only.
# Never expose this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# App / API.
NEXT_PUBLIC_APP_URL=http://localhost:3000
INTERNAL_API_SECRET=

# ShipStation, server/backend only.
# ShipStation is not connected yet. Keep these empty until the integration phase.
SHIPSTATION_API_KEY=
SHIPSTATION_API_SECRET=
SHIPSTATION_BASE_URL=
SHIPSTATION_WEBHOOK_SECRET=

# Legacy direct tracking, server/backend only.
USPS_API_URL=
USPS_API_KEY=
USPS_TRACKING_API_URL=
USPS_TRACKING_API_KEY=

UPS_API_URL=
UPS_API_KEY=
UPS_TRACKING_API_URL=
UPS_TRACKING_API_KEY=

FEDEX_API_URL=
FEDEX_API_KEY=
FEDEX_TRACKING_API_URL=
FEDEX_TRACKING_API_KEY=

DHL_API_URL=
DHL_API_KEY=
DHL_TRACKING_API_URL=
DHL_TRACKING_API_KEY=

# Future payments, server/backend only.
PAYMENT_PROVIDER_SECRET=
WEBHOOK_PAYMENT_SECRET=

# Notes:
# - NEXT_PUBLIC_* variables are visible to the browser.
# - ShipStation keys, carrier keys, SUPABASE_SERVICE_ROLE_KEY, payment secrets,
#   and webhook secrets must never use NEXT_PUBLIC_*.
# - Do not commit .env, .env.local, or any file with real credentials.
