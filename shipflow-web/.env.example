# ShipFlow Web environment example.
# Do not put real secrets in this file.
# Copy to .env.local for local development and fill values there.

# Supabase public, visible in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase private, server/backend only.
# Never expose this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# App / API.
NEXT_PUBLIC_APP_URL=http://localhost:3000
INTERNAL_API_SECRET=

# Google Maps / Places (optional).
# If set, /crear-guia shows address autocomplete powered by Google Places.
# If empty, the form falls back to manual address fields — no functionality is lost.
# Restrict this key by HTTP referrer in Google Cloud Console before using in production.
# Requires: Maps JavaScript API + Places API enabled in the project.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ShipStation, server/backend only.
# Use shipengine for the new ShipStation/ShipEngine sandbox API.
# In shipengine mode only SHIPSTATION_API_KEY is required for rates.
SHIPSTATION_API_MODE=
SHIPSTATION_API_KEY=
SHIPSTATION_API_SECRET=
SHIPSTATION_BASE_URL=
SHIPSTATION_WEBHOOK_SECRET=

# ShipFlow label storage (optional, for future Supabase Storage integration).
# If set, label PDFs can be uploaded and served from Storage instead of being returned as base64.
# Leave empty to use base64 response (default for FASE 4D).
SHIPFLOW_LABELS_BUCKET=
SHIPFLOW_LABELS_PUBLIC_BASE_URL=

# Multi-provider logistics — server/backend only.
# SHIPPO_API_KEY: activado para RATES en FASE 5.15 (labels pendientes).
#   Con key: Shippo se incluye en la cotización multi-provider automáticamente.
#   Sin key: Shippo se ignora en el RateAggregator.
#   Auth: ShippoToken <key> (no NEXT_PUBLIC — nunca exponer al cliente).
# EASYPOST_API_KEY: activado para RATES en FASE 5.12 (labels pendientes).
# EASYSHIP_API_KEY + EASYSHIP_BASE_URL: activado para RATES en FASE 5.18 (labels pendientes).
SHIPPO_API_KEY=
EASYPOST_API_KEY=
EASYSHIP_API_KEY=
EASYSHIP_BASE_URL=

# Legacy direct tracking, server/backend only.
USPS_API_URL=
USPS_API_KEY=
USPS_TRACKING_API_URL=
USPS_TRACKING_API_KEY=

UPS_API_URL=
UPS_API_KEY=
UPS_TRACKING_API_URL=
UPS_TRACKING_API_KEY=

FEDEX_API_URL=
FEDEX_API_KEY=
FEDEX_TRACKING_API_URL=
FEDEX_TRACKING_API_KEY=

DHL_API_URL=
DHL_API_KEY=
DHL_TRACKING_API_URL=
DHL_TRACKING_API_KEY=

# Future payments, server/backend only.
PAYMENT_PROVIDER_SECRET=
WEBHOOK_PAYMENT_SECRET=

# Notes:
# - NEXT_PUBLIC_* variables are visible to the browser.
# - ShipStation keys, carrier keys, SUPABASE_SERVICE_ROLE_KEY, payment secrets,
#   and webhook secrets must never use NEXT_PUBLIC_*.
# - Do not commit .env, .env.local, or any file with real credentials.
