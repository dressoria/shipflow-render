## ShipFlow Mobile environment example.
## Do not put real secrets in this file.
## Copy to .env for local development and fill values there.
##
## EXPO_PUBLIC_* variables are visible inside the mobile app.
## Do not put ShipStation keys, carrier keys, service_role, payment secrets,
## or webhook secrets in mobile.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_TRACKING_API_URL=

## Future rates/labels should use the ShipFlow backend through
## EXPO_PUBLIC_API_BASE_URL, not provider APIs directly.
